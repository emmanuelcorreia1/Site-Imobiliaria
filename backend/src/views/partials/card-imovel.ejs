<article class="propertyCard">
  <div class="propertyThumb">
    <img src="<%= imovel.imagem %>" alt="<%= imovel.titulo %>" />
    <span class="propertyTag"><%= imovel.finalidade === "venda" ? "Venda" : "Locacao" %></span>
  </div>

  <div class="propertyBody">
    <div class="propertyMeta">
      <span><%= imovel.categoria %></span>
      <span>Cod. <%= imovel.codigo %></span>
    </div>

    <h3><%= imovel.titulo %></h3>
    <p><%= imovel.cidade %> - <%= imovel.bairro %></p>

    <div class="propertySpecs">
      <span><%= imovel.quartos %> quartos</span>
      <span><%= imovel.banheiros %> banheiros</span>
      <span><%= imovel.area %> m2</span>
    </div>

    <div class="propertyFooter">
      <strong>
        R$ <%= imovel.preco.toLocaleString("pt-BR") %>
        <%= imovel.finalidade === "locacao" ? "/mes" : "" %>
      </strong>
      <a href="/imoveis/<%= imovel.codigo %>">Ver detalhes</a>
    </div>
  </div>
</article>

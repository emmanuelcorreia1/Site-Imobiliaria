<footer class="footer">
  <div class="divFooter">
    <div class="footerMarca">
      <img
        src="/assets/images/Logo branca sem fundo.png"
        alt="Logo Mondialle"
        class="footerLogo"
      />

      <p>
        A <%= empresa.nome %> conecta pessoas a oportunidades de venda e locacao
        com transparencia, acompanhamento proximo e foco no melhor negocio.
      </p>

      <div class="redeSocial">
        <a href="<%= empresa.instagram %>" aria-label="Instagram">
          <i class="fa-brands fa-instagram"></i>
        </a>
        <a href="<%= empresa.facebook %>" aria-label="Facebook">
          <i class="fa-brands fa-facebook"></i>
        </a>
      </div>

      <span class="footerTexto">
        (c) 2026 <%= empresa.nome %>. Todos os direitos reservados.
      </span>
    </div>

    <div class="footerIndices">
      <h3>Navegacao</h3>
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/venda">Venda</a></li>
        <li><a href="/locacao">Locacao</a></li>
        <li><a href="/imoveis">Catalogo</a></li>
        <li><a href="/contato">Contato</a></li>
      </ul>
    </div>

    <div class="footerIndices">
      <h3>Contato</h3>
      <ul class="footerContato">
        <li>Email - <%= empresa.email %></li>
        <li>Telefone - <%= empresa.telefone %></li>
        <li>Localizacao - <%= empresa.endereco %></li>
      </ul>
    </div>
  </div>

  <div class="creditosFooter">
    Plataforma web da Mondialle com busca, catalogo e paginas institucionais.
  </div>

  <div class="mondialleGrandeFooter">MONDIALLE</div>
</footer>

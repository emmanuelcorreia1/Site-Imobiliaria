<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <%- include("../partials/cabecalho-head", { titulo }) %>
  </head>
  <body>
    <%- include("../partials/cabecalho", { pagina, empresa }) %>

    <main class="internalPage">
      <section class="pageHero">
        <span class="sectionEyebrow">Catalogo Mondialle</span>
        <h1><%= cabecalho %></h1>
        <p><%= introducao %></p>
      </section>

      <%- include("../partials/form-busca", {
        acao: pagina === "venda" ? "/venda" : pagina === "locacao" ? "/locacao" : "/imoveis",
        busca,
        catalogo,
        consulta,
        textoBotao: "Atualizar busca",
        tituloBusca: "Refine sua pesquisa"
      }) %>

      <section class="resultsSection">
        <div class="sectionHeading">
          <div>
            <span class="sectionEyebrow">Resultado</span>
            <h2><%= busca.itens.length %> imoveis encontrados</h2>
          </div>
        </div>

        <% if (busca.itens.length) { %>
          <div class="propertyGrid">
            <% busca.itens.forEach((imovel) => { %>
              <%- include("../partials/card-imovel", { imovel }) %>
            <% }) %>
          </div>
        <% } else { %>
          <div class="emptyState">
            <h3>Nenhum resultado encontrado.</h3>
            <p>Altere filtros, cidade ou faixa de preco para ver outras oportunidades.</p>
          </div>
        <% } %>
      </section>
    </main>

    <%- include("../partials/rodape", { empresa }) %>
    <script src="/js/interface.js"></script>
  </body>
</html>

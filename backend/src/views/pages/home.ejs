<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <%- include("../partials/cabecalho-head", { titulo }) %>
  </head>
  <body>
    <%- include("../partials/cabecalho", { pagina, empresa }) %>

    <section class="hero">
      <div class="textoPrincipal">
        <h1>
          Encontre o imovel ideal
          <br />
          com a <span class="mondialle">MONDIALLE</span>
        </h1>
        <p class="heroIntro">
          Busca inteligente por venda e locacao, com atendimento local e acompanhamento em cada etapa.
        </p>
      </div>

      <div class="imagesSection">
        <img
          src="/assets/images/Casas_2d.png"
          alt="Ilustracao da cidade"
          class="cidadeLinha"
        />
        <img src="/assets/images/Terra.png" alt="Planeta Terra" class="terra" />
        <div class="cirBlur"></div>
      </div>
    </section>

    <main class="principal">
      <%- include("../partials/form-busca", {
        acao: "/imoveis",
        busca,
        catalogo,
        consulta,
        textoBotao: "Buscar imoveis",
        tituloBusca: "Filtre por perfil, localizacao e faixa de preco"
      }) %>

      <section class="resultsSection featuredSection">
        <div class="sectionHeading">
          <div>
            <span class="sectionEyebrow">Destaques</span>
            <h2>Imoveis em destaque</h2>
          </div>
          <a href="/imoveis" class="sectionLink">Ver catalogo completo</a>
        </div>

        <div class="propertyGrid">
          <% imoveisDestaque.forEach((imovel) => { %>
            <%- include("../partials/card-imovel", { imovel }) %>
          <% }) %>
        </div>
      </section>

      <section class="resultsSection">
        <div class="sectionHeading">
          <div>
            <span class="sectionEyebrow">Resultado da busca</span>
            <h2><%= busca.itens.length %> imoveis encontrados</h2>
          </div>
          <a href="/api/imoveis" class="sectionLink">API JSON</a>
        </div>

        <% if (busca.itens.length) { %>
          <div class="propertyGrid">
            <% busca.itens.forEach((imovel) => { %>
              <%- include("../partials/card-imovel", { imovel }) %>
            <% }) %>
          </div>
        <% } else { %>
          <div class="emptyState">
            <h3>Nenhum imovel encontrado com esses filtros.</h3>
            <p>Tente ampliar a faixa de preco ou remover algum criterio para ver mais opcoes.</p>
          </div>
        <% } %>
      </section>
    </main>

    <%- include("../partials/rodape", { empresa }) %>
    <script src="/js/interface.js"></script>
  </body>
</html>

  <form class="caixaBusca propertySearchForm" action="<%= acao %>" method="get">
    <div class="gridBuscaCima">
      <div class="dropdownFiltro" data-dropdown data-dropdown-label="Finalidade">
        <button class="dropdownAlternar" type="button" data-dropdown-toggle>
          <span class="dropdownTexto" data-dropdown-text>
            <%= busca.filtros.finalidade.length ? `(${busca.filtros.finalidade.length}) Selecionados` : "Finalidade" %>
          </span>
          <span class="iconeSeta"><i class="fa-solid fa-chevron-down"></i></span>
        </button>

        <div class="dropdownList">
          <div class="dropdownBase">
            <div class="checkboxWrap">
              <% catalogo.finalidades.forEach((finalidade) => { %>
                <label class="checkboxLabel">
                  <input
                    type="checkbox"
                    name="finalidade"
                    value="<%= finalidade %>"
                    <%= busca.filtros.finalidade.includes(finalidade) ? "checked" : "" %>
                    data-dropdown-input
                  />
                  <span class="checkboxCustom"></span>
                  <span class="checkboxTexto">
                    <%= finalidade === "venda" ? "Venda" : "Locacao" %>(<%= catalogo.contagens.finalidades[finalidade] || 0 %>)
                  </span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="dropdownFiltro" data-dropdown data-dropdown-label="Categoria">
        <button class="dropdownAlternar" type="button" data-dropdown-toggle>
          <span class="dropdownTexto" data-dropdown-text>
            <%= busca.filtros.categoria.length ? `(${busca.filtros.categoria.length}) Selecionados` : "Categoria" %>
          </span>
          <span class="iconeSeta"><i class="fa-solid fa-chevron-down"></i></span>
        </button>

        <div class="dropdownList">
          <div class="dropdownBase">
            <div class="checkboxWrap">
              <% catalogo.categorias.forEach((categoria) => { %>
                <label class="checkboxLabel">
                  <input
                    type="checkbox"
                    name="categoria"
                    value="<%= categoria %>"
                    <%= busca.filtros.categoria.includes(categoria) ? "checked" : "" %>
                    data-dropdown-input
                  />
                  <span class="checkboxCustom"></span>
                  <span class="checkboxTexto"><%= categoria %>(<%= catalogo.contagens.categorias[categoria] || 0 %>)</span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="dropdownFiltro" data-dropdown data-dropdown-label="Cidade">
        <button class="dropdownAlternar" type="button" data-dropdown-toggle>
          <span class="dropdownTexto" data-dropdown-text>
            <%= busca.filtros.cidade.length ? `(${busca.filtros.cidade.length}) Selecionados` : "Cidade" %>
          </span>
          <span class="iconeSeta"><i class="fa-solid fa-chevron-down"></i></span>
        </button>

        <div class="dropdownList">
          <div class="dropdownBase">
            <div class="checkboxWrap">
              <% catalogo.cidades.forEach((cidade) => { %>
                <label class="checkboxLabel">
                  <input
                    type="checkbox"
                    name="cidade"
                    value="<%= cidade %>"
                    <%= busca.filtros.cidade.includes(cidade) ? "checked" : "" %>
                    data-dropdown-input
                  />
                  <span class="checkboxCustom"></span>
                  <span class="checkboxTexto"><%= cidade %>(<%= catalogo.contagens.cidades[cidade] || 0 %>)</span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="dropdownFiltro" data-dropdown data-dropdown-label="Bairro">
        <button class="dropdownAlternar" type="button" data-dropdown-toggle>
          <span class="dropdownTexto" data-dropdown-text>
            <%= busca.filtros.bairro.length ? `(${busca.filtros.bairro.length}) Selecionados` : "Bairro" %>
          </span>
          <span class="iconeSeta"><i class="fa-solid fa-chevron-down"></i></span>
        </button>

        <div class="dropdownList">
          <div class="dropdownBase">
            <div class="checkboxWrap">
              <% catalogo.bairros.forEach((bairro) => { %>
                <label class="checkboxLabel">
                  <input
                    type="checkbox"
                    name="bairro"
                    value="<%= bairro %>"
                    <%= busca.filtros.bairro.includes(bairro) ? "checked" : "" %>
                    data-dropdown-input
                  />
                  <span class="checkboxCustom"></span>
                  <span class="checkboxTexto"><%= bairro %>(<%= catalogo.contagens.bairros[bairro] || 0 %>)</span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>

      <div class="dropdownFiltro" data-dropdown data-dropdown-label="Quartos">
        <button class="dropdownAlternar" type="button" data-dropdown-toggle>
          <span class="dropdownTexto" data-dropdown-text>
            <%= busca.filtros.quartos.length ? `(${busca.filtros.quartos.length}) Selecionados` : "Quartos" %>
          </span>
          <span class="iconeSeta"><i class="fa-solid fa-chevron-down"></i></span>
        </button>

        <div class="dropdownList">
          <div class="dropdownBase">
            <div class="checkboxWrap">
              <% catalogo.quartos.forEach((quarto) => { %>
                <label class="checkboxLabel">
                  <input
                    type="checkbox"
                    name="quartos"
                    value="<%= quarto %>"
                    <%= busca.filtros.quartos.includes(quarto) ? "checked" : "" %>
                    data-dropdown-input
                  />
                  <span class="checkboxCustom"></span>
                  <span class="checkboxTexto">
                    <%= quarto %> quarto<%= quarto > 1 ? "s" : "" %>(<%= catalogo.contagens.quartos[quarto] || 0 %>)
                  </span>
                </label>
              <% }) %>
            </div>
          </div>
        </div>
      </div>
    </div>

    <div class="gridBuscaBaixo">
      <div class="filtroPreco">
        <div class="valores">
          <div class="valorBox" data-price-min-label>R$ 0</div>
          <div class="valorBox" data-price-max-label>R$ <%= catalogo.precoMaximo.toLocaleString("pt-BR") %></div>
        </div>

        <div class="divSlider">
          <div class="slider"></div>
          <div class="sliderRange" data-slider-range></div>

          <input
            type="range"
            min="0"
            max="<%= catalogo.precoMaximo %>"
            value="<%= busca.filtros.precoMinimo %>"
            step="500"
            class="inputRange"
            data-range-min
          />

          <input
            type="range"
            min="0"
            max="<%= catalogo.precoMaximo %>"
            value="<%= busca.filtros.precoMaximo === Number.MAX_SAFE_INTEGER ? catalogo.precoMaximo : busca.filtros.precoMaximo %>"
            step="500"
            class="inputRange"
            data-range-max
          />

          <input type="hidden" name="precoMin" value="<%= busca.filtros.precoMinimo %>" data-range-min-hidden />
          <input
            type="hidden"
            name="precoMax"
            value="<%= busca.filtros.precoMaximo === Number.MAX_SAFE_INTEGER ? catalogo.precoMaximo : busca.filtros.precoMaximo %>"
            data-range-max-hidden
          />
        </div>
      </div>

      <div class="botaoBuscar">
        <button type="submit" class="btnBuscar"><%= textoBotao %></button>
      </div>

      <div class="campoCodigo">
        <input
          type="text"
          placeholder="Codigo do imovel"
          class="inputCodigo"
          name="codigo"
          value="<%= consulta.codigo || '' %>"
          maxlength="3"
        />
      </div>
    </div>
  </form>
</section>

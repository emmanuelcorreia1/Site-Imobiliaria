<footer class="footer">
  <div class="divFooter">
    <div class="footerMarca">
      <img
        src="/assets/images/Logo branca sem fundo.png"
        alt="footer Logo"
        class="footerLogo"
      />

      <p>
        <%= empresa.nome %> conecta pessoas as melhores oportunidades do
        mercado imobiliario, com transparencia, seguranca e atendimento
        personalizado em cada negociacao.
      </p>

      <div class="redeSocial">
        <a
          href="<%= empresa.instagram %>"
          aria-label="Instagram"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-brands fa-instagram"></i>
        </a>
        <a
          href="<%= empresa.facebook %>"
          aria-label="Facebook"
          target="_blank"
          rel="noopener noreferrer"
        >
          <i class="fa-brands fa-facebook"></i>
        </a>
      </div>

      <span class="footerTexto">
        © 2026 <%= empresa.nome %>. Todos os direitos reservados.
      </span>
    </div>

    <div class="footerIndices">
      <h3>Navegacao</h3>
      <ul>
        <li><a href="/">Inicio</a></li>
        <li><a href="/venda">Venda</a></li>
        <li><a href="/locacao">Locacao</a></li>
        <li><a href="/sobre">Sobre a Mondialle</a></li>
        <li><a href="/contato">Contato</a></li>
      </ul>
    </div>

    <div class="footerIndices">
      <h3>Contato</h3>
      <ul class="footerContato">
        <li>Email - <%= empresa.email %></li>
        <li>Telefone - <%= empresa.telefone %></li>
        <li>Localizacao - <%= empresa.endereco %></li>
      </ul>
    </div>
  </div>

  <div class="creditosFooter">
    Design e Desenvolvimento do site por
    <span>Emmanuel Scharnoski Correia</span>
  </div>

  <div class="mondialleGrandeFooter">MONDIALLE</div>
</footer>

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <%- include("../partials/header-head", { titulo }) %>
  </head>
  <body>
    <%- include("../partials/header", { pagina, empresa }) %>

    <main class="internalPage">
      <section class="pageHero">
        <span class="sectionEyebrow">Fale com a equipe</span>
        <h1>Contato</h1>
        <p>
          Use os canais abaixo para anunciar um imovel, agendar visita ou tirar duvidas sobre compra e locacao.
        </p>
      </section>

      <section class="contentSection infoGrid">
        <article class="infoCard">
          <h2>Telefone</h2>
          <p><%= empresa.telefone %></p>
        </article>
        <article class="infoCard">
          <h2>Email</h2>
          <p><%= empresa.email %></p>
        </article>
        <article class="infoCard">
          <h2>Endereco</h2>
          <p><%= empresa.endereco %></p>
        </article>
      </section>
    </main>

    <%- include("../partials/rodape", { empresa }) %>
  </body>
</html>

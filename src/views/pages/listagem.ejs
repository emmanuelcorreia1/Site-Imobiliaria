<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include("../partials/header-head", { titulo }) %>
  <link rel="stylesheet" href="/assets/css/vendaLocacao.css">
</head>

<body>
  <%- include("../partials/header", { pagina, empresa }) %>

    <main class="vendaLocacao">
      <section class="tituloPagina">
        <h1>
          <%= cabecalho %>
        </h1>
        <div class="cirBlur2"></div>
      </section>
      
      <%- include("../partials/form-busca", { acao: pagina==="venda" ? "/venda" : pagina==="locacao" ? "/locacao"
        : "/imoveis" , busca, catalogo, consulta, textoBotao: "Atualizar busca" , tituloBusca: "Refine sua pesquisa" })
        %>
        <div class="divPrincipal2">
          <section class="resultadoQuant">
            <div class="result">
              <div class="resultadoTitulo">
                <h2>
                  <%= busca.itens.length %> imoveis encontrados
                </h2>
              </div>
            </div>

            <% if (busca.itens.length) { %>
              <div class="destaque">
                <div class="gridImoveis">
                  <% busca.itens.forEach((imovel)=> { %>
                    <%- include("../partials/card-imovel-pequeno", { imovel }) %>
                      <% }) %>
                </div>
              </div>
              <% } else { %>
                <div class="naoEncontrado">
                  <h3>Nenhum resultado encontrado.</h3>
                  <p>Altere filtros, cidade ou faixa de preco para ver outras oportunidades.</p>
                </div>
                <% } %>
          </section>
        </div>
    </main>

    <%- include("../partials/rodape", { empresa }) %>
      <script src="/assets/js/interface.js"></script>
</body>

</html>
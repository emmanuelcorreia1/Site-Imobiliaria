<!DOCTYPE html>
<html lang="pt-BR">

<head>
  <%- include("../partials/header-head", { titulo }) %>
</head>

<body>
  <%- include("../partials/header", { pagina, empresa }) %>

    <section class="hero">
      <div class="textoPrincipal">
        <h1>
          Encontre o imóvel ideal <br />
          com a <span class="mondialle">MONDIALLE</span>
        </h1>
      </div>

      <div class="imagesSection">
        <img src="/assets/images/Casas_2d.png" alt="Ilustracao da cidade" class="cidadeLinha" />
        <img src="/assets/images/Terra.png" alt="Planeta Terra" class="terra" />
        <div class="cirBlur"></div>
      </div>
    </section>

    <%- include("../partials/form-busca", { acao: "/imoveis" , busca, catalogo, consulta, textoBotao: "Buscar imoveis" ,
      tituloBusca: "Filtre por perfil, localizacao e faixa de preco" }) %>

      <main class="principal">
        <section class="sectionPrincipal">
          <div class="divPrincipal">
            <div class="destaque">
              <h2 class="tituloDestaques">Imóveis em Destaque</h2>
              <div class="gridImoveis">
                <% imoveisDestaque.forEach((imovel)=> { %>
                  <%- include("../partials/card-imovel", { imovel }) %>
                <% }) %>
              </div>
            </div>
          </div>
        </section>
        
          <% if (busca.itens.length) { %>
            <div class="propertyGrid">
              <% busca.itens.forEach((imovel)=> { %>
                <%- include("../partials/card-imovel", { imovel }) %>
                  <% }) %>
            </div>
            <% } else { %>
              <div class="emptyState">
                <h3>Nenhum imovel encontrado com esses filtros.</h3>
                <p>Tente ampliar a faixa de preco ou remover algum criterio para ver mais opcoes.</p>
              </div>
              <% } %>
        </section>
      </main>

      <%- include("../partials/rodape", { empresa }) %>
        <script src="/assets/js/interface.js"></script>
</body>

</html>
